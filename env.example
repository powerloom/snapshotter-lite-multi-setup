# this is the top level env file to be used by the multi node setup
# DO NOT EDIT THIS FILE KTHX
SOURCE_RPC_URL=<source-rpc-url>
SIGNER_ACCOUNT_ADDRESS=<signer-account-address>
SIGNER_ACCOUNT_PRIVATE_KEY=<signer-account-private-key>
WALLET_HOLDER_ADDRESS=<wallet-holder-address>
POWERLOOM_RPC_URL=https://rpc-v2.powerloom.network
TELEGRAM_CHAT_ID=<telegram-chat-id>
TELEGRAM_REPORTING_URL=https://tg-testing.powerloom.io/
TELEGRAM_MESSAGE_THREAD_ID=<telegram-thread-id>
LITE_NODE_BRANCH=master
LOCAL_COLLECTOR_IMAGE_TAG=master

# BDS DSV overrides (uncomment to override defaults)
#LOCAL_COLLECTOR_PORT=50051
#LOCAL_COLLECTOR_P2P_PORT=8001
#LOCAL_COLLECTOR_HEALTH_CHECK_PORT=8080
#CONNECTION_REFRESH_INTERVAL_SEC=300

# Connection manager
#CONN_MANAGER_LOW_WATER=100
#CONN_MANAGER_HIGH_WATER=400

# Stream pool
#MAX_STREAM_POOL_SIZE=2
#MAX_STREAM_QUEUE_SIZE=1000
#STREAM_HEALTH_CHECK_TIMEOUT_MS=5000
#STREAM_WRITE_TIMEOUT_MS=5000
#MAX_WRITE_RETRIES=3
#MAX_CONCURRENT_WRITES=10
#STREAM_POOL_HEALTH_CHECK_INTERVAL=60000
#WRITE_SEMAPHORE_TIMEOUT_SEC=5

# Custom compute repo (uncomment to override sources.json values)
#SNAPSHOTTER_COMPUTE_REPO=
#SNAPSHOTTER_COMPUTE_REPO_BRANCH=
#SNAPSHOTTER_COMPUTE_REPO_COMMIT=

# Mesh
#MESH_SUBMISSION_RATE_LIMIT=100
#MESH_SUBMISSION_BURST_SIZE=200
#MAX_MESH_PUBLISH_GOROUTINES=500
#MESH_PUBLISH_QUEUE_SIZE=1000
